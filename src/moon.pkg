import {
  "moonbitlang/core/json",
  "justjavac/ffi",
}

options(
  link: {
    "native": {
      "cc-flags": "-fwrapv -fsanitize=address -fsanitize=undefined",
      "cc-link-flags": "-Llib -lwebview",
    },
  },
  "native-stub": [ "stub.c" ],
  "supported-targets": [ "native" ],
  targets: {
    "binding.mbt": [ "native" ],
    "command.mbt": [ "native" ],
    "webview.mbt": [ "native" ],
  },
)
