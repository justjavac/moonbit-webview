{
  "is-main": true,
  "import": [
    {
      "path": "justjavac/webview",
      "alias": "webview"
    }
  ],
  "supported-targets": ["native"],
  "targets": {
    "main.mbt": ["native"]
  },
  "link": {
    "native": {
      "cc" : "$CC",
      "cc-flags": "$CC_FLAGS",
      "cc-link-flags": "$CC_LINK_FLAGS"
    }
  }
}
