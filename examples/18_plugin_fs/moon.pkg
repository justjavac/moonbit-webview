import {
  "moonbitlang/core/json",
  "justjavac/webview",
}

options(
  "is-main": true,
  link: {
    "native": {
      "cc-flags": "-fwrapv -fsanitize=address -fsanitize=undefined",
      "cc-link-flags": "-L../lib -lwebview",
    },
  },
  // HTML embedding handled in main.mbt resource to avoid duplicate symbol conflicts
  "supported-targets": [ "native" ],
  targets: { "main.mbt": [ "native" ], "plugin_fs.mbt": [ "native" ] },
)
