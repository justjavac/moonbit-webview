import {
  "moonbitlang/core/encoding/utf8",
  "moonbitlang/core/json",
  "justjavac/ffi",
  "justjavac/webview",
}

options(
  link: {
    "native": {
      "cc-flags": "-fwrapv -fsanitize=address -fsanitize=undefined",
      "cc-link-flags": "-L../lib -lwebview",
    },
  },
  "native-stub": [ "fs_native.c" ],
  targets: { "plugin.mbt": [ "native" ] },
)
